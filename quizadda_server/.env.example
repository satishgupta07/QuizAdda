# QuizAdda Server — Environment Variables
#
# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit real credentials.
#
# To load these into a local run:
#   - IntelliJ: paste them into the Run Configuration > Environment variables
#   - PowerShell: `Get-Content .env | ForEach-Object { $name,$value = $_.split('='); Set-Item -Path "env:$name" -Value $value }`
#   - Render/Railway: add each one in the dashboard's Environment section

# --- Server ---
# Port the Spring Boot app listens on. Locally 9797; cloud providers (Render, Railway) inject their own PORT.
PORT=9797

# --- Neon Postgres ---
# Get these from your Neon dashboard: https://console.neon.tech
# The dashboard gives you a `postgresql://USER:PASS@HOST/DB?sslmode=require` string —
# split it into the three vars below and prefix the URL with `jdbc:`.

# Full JDBC URL. Must start with `jdbc:postgresql://` and include `?sslmode=require` for Neon.
SPRING_DATASOURCE_URL=jdbc:postgresql://ep-your-endpoint.region.aws.neon.tech/neondb?sslmode=require

# Database username (Neon default is `neondb_owner`).
SPRING_DATASOURCE_USERNAME=neondb_owner

# Database password from the Neon connection string.
SPRING_DATASOURCE_PASSWORD=replace-me

# --- JWT ---
# Secret used to sign HS256 access tokens. MUST be at least 32 characters (UTF-8 bytes).
# Generate one with PowerShell:
#   -join ((48..57)+(65..90)+(97..122) | Get-Random -Count 64 | ForEach-Object {[char]$_})
JWT_SECRET=replace-with-a-long-random-string-at-least-32-characters

# Token lifetime in milliseconds. Default is 5 hours (18,000,000 ms).
JWT_EXPIRATION_MS=18000000

# --- CORS ---
# Comma-separated list of origins allowed to call this API.
# Locally: Angular dev server (http://localhost:4200).
# Production: your Vercel URL (e.g. https://quizadda.vercel.app).
# Include both if you want to hit the deployed backend from local dev.
CORS_ALLOWED_ORIGINS=http://localhost:4200,https://quizadda.vercel.app
